# ---------------------------------------------------------------------------
# IP Geolocation Service — environment variables
# Copy this file to .env and adjust values for your environment.
# ---------------------------------------------------------------------------

# Geolocation provider to use.
# Supported values: ip_api | ipapi_co | maxmind
# Default: ip_api
GEO_PROVIDER=ip_api

# Optional API key for authenticated provider tiers.
# Required for: ipapi.co (paid plan)
# Not used by:  ip_api, maxmind
# GEO_API_KEY=your-api-key-here

# Path to the MaxMind GeoLite2-City.mmdb file.
# Required only when GEO_PROVIDER=maxmind.
# MAXMIND_DB_PATH=GeoLite2-City.mmdb

# Timeout (in seconds) for outbound HTTP requests to geolocation APIs.
# Default: 5.0
# HTTP_TIMEOUT=5.0

# Log level. One of: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Default: INFO
# LOG_LEVEL=INFO
